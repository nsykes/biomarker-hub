# =============================================================================
# Biomarker Hub — environment variables
#
# Copy to `.env.local` and fill in. Values are validated at build time
# by `lib/env.ts`; missing or malformed values will fail the build.
# =============================================================================

# Neon Postgres connection string.
# Use the Vercel-managed Neon project (NOT `buki-project`). Get from the
# Vercel project dashboard → Storage → Neon → Connection string.
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon Auth base URL (usually matches your app URL).
NEON_AUTH_BASE_URL=https://biomarker-hub.vercel.app

# Session cookie signing secret. Must be 32+ chars.
# Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# Optional — fallback OpenRouter API key. Users supply their own keys in
# Settings; this is only used for app-level testing/tooling.
# OPENROUTER_API_KEY=sk-or-v1-...

# Upstash Redis — required in production for rate limiting.
# Easiest setup: Vercel dashboard → Storage → Upstash for Redis → free tier.
# That flow auto-injects the env vars (either UPSTASH_REDIS_REST_* or the
# legacy KV_REST_API_* names — `lib/env.ts` accepts both).
# Or set manually from https://console.upstash.com → database's REST API tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — public-facing app URL used to build absolute links (e.g., share
# URLs, OAuth redirect hints). Falls back to `VERCEL_PROJECT_PRODUCTION_URL`
# then `http://localhost:3000` if unset.
# NEXT_PUBLIC_APP_URL=https://biomarker-hub.vercel.app
